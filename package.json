{
  "name": "t2helix",
  "version": "0.10.1",
  "description": "Persistent recall and pre-action compass for Claude Code. Local-only, SQLite-backed.",
  "license": "Apache-2.0",
  "author": "Anthony Vasquez Sr. (templetwo)",
  "type": "commonjs",
  "engines": {
    "node": ">=20 <27"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.10.0"
  },
  "scripts": {
    "smoke": "node test/smoke.js",
    "regression": "node test/regression.js",
    "integration": "node test/integration.js",
    "test": "node test/smoke.js && node test/regression.js && node test/integration.js && node test/sse-contract.js && node test/import-atlas.js && node test/atlas-acceptance.js && node test/sync-stack.js",
    "sse-contract": "node test/sse-contract.js",
    "test:import-atlas": "node test/import-atlas.js",
    "test:atlas-acceptance": "node test/atlas-acceptance.js",
    "serve": "node mcp/server.js --transport sse --port 3742",
    "rebuild": "npm rebuild better-sqlite3",
    "doctor": "node scripts/doctor.js",
    "release:doctor": "node scripts/release-doctor.js",
    "policy-check": "node scripts/check-policy-diff.js",
    "export-manifest": "node scripts/export.js",
    "import-manifest": "node scripts/import.js",
    "install-commands": "node scripts/install-commands.js",
    "dashboard": "node dashboard/server.js",
    "redact-sweep": "node scripts/redact-sweep.js",
    "import-atlas": "node scripts/import-atlas.js",
    "sync-stack": "node scripts/sync-stack.js"
  }
}
