  "type": "commonjs",
  "engines": {
    "node": ">=20 <27"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.10.0"
  },
  "scripts": {
    "smoke": "node test/smoke.js",
